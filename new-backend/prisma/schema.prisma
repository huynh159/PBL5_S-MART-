generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  DELIVERED
  CANCELLED
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(255)
  description String?   @db.VarChar(500)
  products    Product[]

  @@map("categories")
}

model User {
  id               Int            @id @default(autoincrement())
  email            String         @unique @db.VarChar(255)
  password         String         @db.VarChar(255)
  role             UserRole       @default(CUSTOMER)
  status           UserStatus     @default(ACTIVE)
  isVerified       Boolean        @default(true) @map("is_verified")
  otpCode          String?        @map("otp_code") @db.VarChar(10)
  otpExpiry        DateTime?      @map("otp_expiry")
  createdAt        DateTime       @default(now()) @map("created_at")
  
  // Customer fields
  address          String?        @db.VarChar(500)
  phone            String?        @db.VarChar(20)
  accumulatedPoints Int           @default(0) @map("accumulated_points")

  // Staff fields
  staffCode        String?        @unique @map("staff_code") @db.VarChar(50)
  position         String?        @db.VarChar(100)
  department       String?        @db.VarChar(100)

  orders           Order[]
  cartItems        CartItem[]
  reviews          Review[]
  messagesSent     Message[]      @relation("SentMessages")
  messagesReceived Message[]      @relation("ReceivedMessages")
  notifications    Notification[]

  @@map("users")
}

model Coupon {
  id              Int      @id @default(autoincrement())
  code            String   @unique @db.VarChar(50)
  discountPercent Int      @map("discount_percent")
  expiryDate      DateTime @map("expiry_date") @db.Date
  isActive        Boolean  @default(true) @map("is_active")
  orders          Order[]

  @@map("coupons")
}

model Product {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(255)
  price         Float
  description   String?        @db.Text
  stock         Int            @default(0)
  imageUrl      String?        @map("image_url") @db.VarChar(500)
  brand         String?        @db.VarChar(100)
  salePrice     Float?         @map("sale_price")
  sku           String?        @unique @db.VarChar(100)
  status        String         @default("ACTIVE") @db.VarChar(20)
  variations    String?        @db.Text // Stored as JSON string
  categoryId    Int            @map("category_id")
  category      Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images        ProductImage[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
  reviews       Review[]

  @@map("products")
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int     @map("product_id")
  imageUrl  String  @map("image_url") @db.VarChar(500)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int         @map("user_id")
  couponId        Int?        @map("coupon_id")
  total           Float
  shippingFee     Float       @default(0) @map("shipping_fee")
  address         String      @db.VarChar(500)
  phone           String      @db.VarChar(20)
  note            String?     @db.VarChar(500)
  paymentMethod   String      @default("COD") @map("payment_method") @db.VarChar(50)
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now()) @map("created_at")
  user            User        @relation(fields: [userId], references: [id], onDelete: Restrict)
  coupon          Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  orderItems      OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int     @map("product_id")
  quantity  Int     @default(1)
  color     String? @db.VarChar(100)
  size      String? @db.VarChar(50)
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

model CartItem {
  id        Int     @id @default(autoincrement())
  userId    Int     @map("user_id")
  productId Int     @map("product_id")
  quantity  Int     @default(1)
  color     String? @db.VarChar(100)
  size      String? @db.VarChar(50)
  price     Float
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("cart_items")
}

model Review {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  productId   Int      @map("product_id")
  rating      Int
  comment     String?  @db.Text
  images      String?  @db.Text // Can be JSON array
  variation   String?  @db.VarChar(255)
  likes       Int      @default(0)
  orderItemId Int?     @map("order_item_id")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("reviews")
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int      @map("sender_id")
  receiverId Int      @map("receiver_id")
  content    String   @db.Text
  status     String   @default("SENT") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at")
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  content   String   @db.Text
  link      String?  @db.VarChar(255)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

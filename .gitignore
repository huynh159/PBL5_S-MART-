# =========================
# Backend (Java / Spring Boot / Maven)
# =========================
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
!backend/.mvn/wrapper/maven-wrapper.properties

# Bỏ qua các file biên dịch và logs của Java
*.class
*.log
*.jar
*.war
*.ear
hs_err_pid*

# =========================
# Frontend (React / Vite / Node.js)
# =========================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/coverage/

# Bỏ qua các logs lỗi của công cụ quản lý package
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Environment Variables (Khóa bí mật)
# =========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# =========================
# IDEs (IntelliJ, Eclipse, VSCode)
# =========================
.idea/
*.iml
*.iws
.project
.classpath
.settings/
.vscode/

# =========================
# OS Files (Mac, Windows)
# =========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
Thumbs.db
ehthumbs.db
$RECYCLE.BIN/

# =========================
# Database (Tùy chọn)
